name=dhcpcd
version=10.1.0
source=https://github.com/NetworkConfiguration/dhcpcd/releases/download/v10.1.0/dhcpcd-10.1.0.tar.xz
sha256=abc307c63853da3199baa5c1e15fd5ede9d68d068b2a59ca14c5a6768e9cc3b7
depends=""
build() {
    ./configure --prefix=/usr --sysconfdir=/etc --libexecdir=/usr/lib/dhcpcd \
        --dbdir=/var/lib/dhcpcd --rundir=/run --privsepuser=dhcpcd
    make
    make DESTDIR="$DESTDIR" install
}
