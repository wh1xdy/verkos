name=curl
version=8.11.0
source=https://curl.se/download/curl-8.11.0.tar.xz
sha256=db59cf0d671ca6e7f5c2c5ec177084a33a79e04c97e71cf183a5cdea235054eb
depends="openssl zlib"
build() {
    ./configure --prefix=/usr --with-openssl --with-zlib --without-libpsl \
        --with-ca-path=/etc/ssl/certs --disable-static --enable-optimize
    make
    make DESTDIR="$DESTDIR" install
}
